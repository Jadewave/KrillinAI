name: Sync to Hugging Face hub
on:
  push:
    branches: [main] # Hoặc master tùy vào nhánh chính của bạn
  workflow_dispatch: # Cho phép chạy thủ công từ tab Actions

jobs:
  sync-to-hub:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
        with:
          fetch-depth: 0
          lfs: true
          
      - name: Push to hub
        env:
          HF_TOKEN: ${{ secrets.HF_TOKEN }}
        run: |
          # Thay 'USERNAME' và 'SPACE_NAME' bằng thông tin của bạn
          git push --force https://USERNAME:$HF_TOKEN@huggingface.co/spaces/USERNAME/SPACE_NAME main
